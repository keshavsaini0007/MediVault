# Copy this to .env and fill in your value

# Option A — same WiFi network (find your IP with `ipconfig` on Windows / `ifconfig` on Mac)
# EXPO_PUBLIC_API_URL=http://192.168.x.x:5000/api/v1

# Option B — ngrok tunnel (works across any network, best for hackathons)
# Run: ngrok http 5000  →  copy the https URL below
# EXPO_PUBLIC_API_URL=https://abc123.ngrok-free.app/api/v1

# Option C — leave unset to use the deployed production backend
